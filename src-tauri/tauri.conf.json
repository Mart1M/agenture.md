{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agenture",
  "version": "0.1.0",
  "identifier": "com.martinm.agenture",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agenture",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWSbgelkaAsFxR0jlWU3/NgN2UrifXpuINAjJ22T5QsXaIhtRFnfqik4",
      "endpoints": [
        "https://github.com/Mart1M/agenture.app/releases/latest/download/latest.json"
      ]
    }
  }
}