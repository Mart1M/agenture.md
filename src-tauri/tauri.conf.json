{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agenture",
  "version": "0.1.4",
  "identifier": "com.martinm.agenture",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agenture",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGMTBEQThERjgyNDg1NTMKUldSVGhTVDRqZG9RenpqamE0Vi9obnFyZ3dRd3lMM2V5a0U4ZGY4ZFVaZmVQNEtIU0NEbVNkVU0K",
      "endpoints": [
        "https://github.com/Mart1M/agenture.md/releases/latest/download/latest.json"
      ]
    }
  }
}